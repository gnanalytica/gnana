# ============================================
# Gnana — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Works on Windows, macOS, and Linux.

# ---- Database (required) ----
# Option 1 (recommended): Neon free tier — https://neon.tech (zero local setup)
# Option 2: Local Postgres — brew install postgresql (macOS), apt install postgresql (Linux), postgresql.org/download (Windows)
DATABASE_URL=postgresql://user:password@localhost:5432/gnana

# ---- LLM Providers (at least one required) ----
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_KEY=AIza...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# ---- Security (required for production) ----
GNANA_API_SECRET=<random-32-chars>
ENCRYPTION_KEY=<random-32-chars>

# ---- Monitoring ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---- Auth (Auth.js / NextAuth) ----
AUTH_SECRET=<random-32-chars>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Server ----
PORT=4000
NODE_ENV=development
