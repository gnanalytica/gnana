{
  "name": "@gnana/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/start.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "start": "node dist/start.js",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@gnana/core": "workspace:*",
    "@gnana/db": "workspace:*",
    "@gnana/provider-base": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@sentry/node": "^10.45.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "jose": "^6.2.2",
    "postgres": "^3.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
